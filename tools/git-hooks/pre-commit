#!/usr/bin/env bash
# pre-commit hook for methodical-cc
#
# When something in plugins/bus/server/ changes (other than the bundle or
# node_modules), rebuild the bundle and stage the result. Filters by path so
# unrelated commits aren't slowed down.
#
# To install in this clone (one-time):
#   git config core.hooksPath tools/git-hooks
#
# Bypass for emergencies (rarely needed):
#   git commit --no-verify

set -euo pipefail

# Find staged changes in the bus server dir, excluding the bundle and node_modules.
CHANGED=$(
  git diff --cached --name-only --diff-filter=ACMR \
    | grep '^plugins/bus/server/' \
    | grep -v 'server\.bundle\.js$' \
    | grep -v '^plugins/bus/server/node_modules/' \
    || true
)

if [ -z "$CHANGED" ]; then
  exit 0
fi

echo "[pre-commit] bus server source changed; rebuilding bundle..."
echo "  changed files:"
echo "$CHANGED" | sed 's/^/    /'
echo

REPO_ROOT="$(git rev-parse --show-toplevel)"
SERVER_DIR="$REPO_ROOT/plugins/bus/server"

if ! command -v node >/dev/null 2>&1; then
  echo "[pre-commit] ERROR: 'node' not found on PATH." >&2
  echo "  Install Node >= 20 to develop the bus server." >&2
  echo "  (To bypass this check for an emergency commit: git commit --no-verify)" >&2
  exit 1
fi

if ! command -v npm >/dev/null 2>&1; then
  echo "[pre-commit] ERROR: 'npm' not found on PATH." >&2
  exit 1
fi

if [ ! -d "$SERVER_DIR/node_modules" ]; then
  echo "[pre-commit] ERROR: $SERVER_DIR/node_modules is missing." >&2
  echo "  Run: cd $SERVER_DIR && npm install" >&2
  echo "  (One-time setup before committing changes to bus server source.)" >&2
  exit 1
fi

# Build
( cd "$SERVER_DIR" && npm run build --silent )

# Stage the resulting bundle so it's part of this commit
git add "$SERVER_DIR/server.bundle.js"

echo "[pre-commit] server.bundle.js rebuilt and staged."
