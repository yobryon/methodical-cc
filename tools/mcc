#!/usr/bin/env bash
# mcc - methodical-cc helper CLI (bash shim)
#
# Locates Python and execs mcc.py with all arguments. The real implementation
# lives in mcc.py — this shim exists for ergonomics and platform parity.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_SCRIPT="$SCRIPT_DIR/mcc.py"

if [ ! -f "$PYTHON_SCRIPT" ]; then
    echo "mcc: cannot find mcc.py at $PYTHON_SCRIPT" >&2
    exit 1
fi

if command -v python3 >/dev/null 2>&1; then
    PYTHON=python3
elif command -v python >/dev/null 2>&1; then
    PYTHON=python
else
    echo "mcc: Python 3 is required but was not found on PATH." >&2
    echo "     Install Python 3.6+ from https://www.python.org/" >&2
    exit 1
fi

exec "$PYTHON" "$PYTHON_SCRIPT" "$@"
