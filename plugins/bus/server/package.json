{
  "name": "@methodical-cc/bus-server",
  "version": "1.0.0",
  "description": "MCP server for the methodical-cc peer messaging bus",
  "type": "module",
  "private": true,
  "main": "server.bundle.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "esbuild server.js --bundle --platform=node --target=node20 --format=esm --outfile=server.bundle.js",
    "start": "node server.bundle.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
